# ============================================================================
# TalentRadar Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# All settings are loaded via config/settings.py using pydantic-settings.
# ============================================================================

# ----------------------------------------------------------------------------
# LLM / AI Services (Required)
# ----------------------------------------------------------------------------
# Groq API key for LLM parsing and generation
# Get one at: https://console.groq.com
GROQ_API_KEY=

# Tavily API key for job posting search and scraping
# Get one at: https://tavily.com
TAVILY_API_KEY=

# ----------------------------------------------------------------------------
# PostgreSQL Database (Required)
# ----------------------------------------------------------------------------
# Database connection details
# In Docker: use 'postgres' as the host
# In local dev: use 'localhost'
POSTGRES_USER=talentRadar
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=talentRadar
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Redis (Required for Celery task queue and caching)
# ----------------------------------------------------------------------------
# In Docker: use 'redis' as the host
# In local dev: use 'localhost'
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------------------
# ChromaDB Vector Store (Required)
# ----------------------------------------------------------------------------
# ChromaDB connection details
# In Docker: use 'chromadb' as the host
# In local dev: use 'localhost'
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ----------------------------------------------------------------------------
# JWT Authentication (Required)
# ----------------------------------------------------------------------------
# Secret key for signing JWT tokens (minimum 32 characters)
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-min-32-chars-secret!!

# JWT algorithm (HS256 recommended for most use cases)
JWT_ALGORITHM=HS256

# Token expiry in minutes (60 = 1 hour)
JWT_EXPIRY_MINUTES=60

# ----------------------------------------------------------------------------
# Google Cloud Storage (Optional - for raw JD blob backup)
# ----------------------------------------------------------------------------
# GCS bucket name for storing raw JD HTML backups
GCS_BUCKET_NAME=talentRadar-raw-jds

# Path to service account JSON file
# Leave empty if running locally or using default credentials
GOOGLE_APPLICATION_CREDENTIALS=

# ----------------------------------------------------------------------------
# Frontend Configuration (Required for Next.js frontend)
# ----------------------------------------------------------------------------
# FastAPI base URL for frontend API calls
# In Docker: use 'http://api:8000'
# In local dev: use 'http://localhost:8000'
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Logging (Optional)
# ----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable JSON structured logging (set to 'true' for production)
JSON_LOGGING=false

# ----------------------------------------------------------------------------
# Rate Limiting (Optional)
# ----------------------------------------------------------------------------
# Maximum requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# ----------------------------------------------------------------------------
# Airflow (Optional - for ingestion DAG scheduling)
# ----------------------------------------------------------------------------
# Airflow executor type: LocalExecutor, CeleryExecutor
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# Airflow webserver port
AIRFLOW_WEB_SERVER_PORT=8080

# ----------------------------------------------------------------------------
# Development / Debug (Optional)
# ----------------------------------------------------------------------------
# Enable FastAPI debug mode (set to 'true' for local dev only)
DEBUG=false

# Enable SQLAlchemy query logging (set to 'true' for debugging)
SQL_ECHO=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
